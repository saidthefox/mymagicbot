# Discord application credentials (https://discord.com/developers/applications)
DISCORD_TOKEN=your-bot-token
CLIENT_ID=your-application-id
GUILD_ID=your-server-id

# Optional: category to nest the per-user p- channels under (a category channel ID)
PRIVATE_CATEGORY_ID=

# Optional: override where tournament data is written (default: ./data)
# MTG_DATA_DIR=/srv/workspaces/mtgdiscordbot/data
